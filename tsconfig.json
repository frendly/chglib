{
  "compilerOptions": {
    // Целевая версия JavaScript для компиляции (ES2022 совместима с Node.js 20+)
    "target": "ES2022",

    // Система модулей: ESNext для поддержки современных ES модулей
    "module": "ESNext",

    // Стратегия разрешения модулей: "bundler" позволяет импортировать без расширений .ts
    "moduleResolution": "bundler",

    // Библиотеки типов, которые будут доступны (ES2022 включает все современные API, DOM для клиентского кода)
    "lib": ["ES2022", "DOM"],

    // Директория для скомпилированных файлов (не используется, т.к. noEmit: true)
    "outDir": "./dist",

    // Корневая директория исходных файлов
    "rootDir": "./",

    // Включить строгую проверку типов
    "strict": true,

    // Совместимость с CommonJS модулями (позволяет импортировать npm пакеты)
    "esModuleInterop": true,

    // Пропустить проверку типов в файлах .d.ts из node_modules (ускоряет компиляцию)
    "skipLibCheck": true,

    // Требовать одинаковый регистр в именах файлов (важно для кроссплатформенности)
    "forceConsistentCasingInFileNames": true,

    // Разрешить импорт JSON файлов как модулей
    "resolveJsonModule": true,

    // Не генерировать .d.ts файлы (типы не нужны, Node выполняет TS напрямую)
    "declaration": false,

    // Не генерировать source maps для .d.ts файлов
    "declarationMap": false,

    // Не генерировать source maps (не нужны, Node выполняет TS напрямую)
    "sourceMap": false,

    // Не компилировать файлы в JavaScript (Node выполняет TypeScript с type stripping)
    "noEmit": true,

    // Разрешить импорты с расширением .ts (нужно для Node ESM при запуске без сборки)
    "allowImportingTsExtensions": true,

    // Алиасы путей для импортов
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "#eleventy": ["./src/eleventy/index.ts"],
      "#types/eleventy": ["./src/types/eleventy.d.ts"],
      "#_data/meta": ["./src/_data/meta.ts"],
      "#const/dateFormats": ["./src/const/dateFormats.ts"]
    }
  },

  // Файлы и директории, которые должны быть включены в компиляцию
  "include": [
    ".eleventy.ts",
    "build-assets.ts",
    "src/**/*.ts"
  ],

  // Файлы и директории, которые должны быть исключены из компиляции
  "exclude": [
    "node_modules",        // Зависимости не проверяем
    "dist"                 // Скомпилированные файлы
  ]
}
