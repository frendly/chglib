Order Allow,Deny
Allow from all

Options +FollowSymLinks
RewriteEngine On

Redirect 301 /bncpost.html /BNP/
Redirect 301 /bnp2018.html /BNP/2018/
Redirect 301 /bnp2017.html /BNP/2017/
Redirect 301 /bnp2016.html /BNP/2016/
Redirect 301 /bnp2015.html /BNP/2015/
Redirect 301 /bnp2014.html /BNP/2014/
Redirect 301 /bnp2013.html /BNP/2013/
Redirect 301 /bnp2012.html /BNP/2012/

# отключаем кеширование html
# подробнее https://stackoverflow.com/a/11724596
<filesMatch "\.(html)$">
  FileETag None
  <ifModule mod_headers.c>
     Header unset ETag
     Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
     Header set Pragma "no-cache"
     Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
  </ifModule>
</filesMatch>